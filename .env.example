# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env
# НЕ КОММИТЬ .env в git!

# Telegram Bot Token (получить у @BotFather)
TG_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (отрицательное число для групп, например -1001234567890)
TG_CHAT_ID=-1001234567890

# Telegram Thread ID (ID топика для forum-групп, или 0 если нет)
TG_THREAD_ID=0

# Путь к папке aviation в workspace (по умолчанию — рядом со скриптом)
# AVIATION_DIR=/path/to/your/workspace/aviation
